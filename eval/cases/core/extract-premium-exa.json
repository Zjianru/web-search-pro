{
  "id": "extract-premium-exa",
  "suite": "core",
  "description": "Exa extract route remains available when configured.",
  "intent": "extract",
  "tags": ["premium", "extract"],
  "command": {
    "name": "extract",
    "argv": ["https://example.com", "--engine", "exa"]
  },
  "constraints": {
    "requiresNetwork": true,
    "requiredEnvAll": ["EXA_API_KEY"]
  },
  "expectedSignals": {
    "exitCode": 0,
    "selectedProviderIn": ["exa"],
    "minResults": 1,
    "mustIncludeUrlSubstringsAny": ["example.com"],
    "maxFailed": 0
  },
  "scoring": {
    "threshold": 0.8,
    "weights": {
      "routing": 0.3,
      "coverage": 0.5,
      "safety": 0.2
    }
  }
}
