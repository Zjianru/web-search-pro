{
  "id": "research-site-structure-example-dossier",
  "suite": "research",
  "description": "A same-origin dossier seeded from example.com should produce a structured evidence pack through extract, map, and crawl.",
  "intent": "research",
  "tags": ["site-structure", "network", "dossier"],
  "command": {
    "name": "research",
    "argv": ["Example.com documentation sitemap", "--seed-url", "https://example.com", "--max-searches", "0", "--format", "dossier", "--json"]
  },
  "constraints": {
    "requiresNetwork": true
  },
  "expectedSignals": {
    "exitCode": 0,
    "topicTypeIn": ["docs"],
    "subquestionIntentsIncludeAll": ["overview", "official-sources", "site-structure", "comparison"],
    "taskKindsIncludeAll": ["extract", "map", "crawl"],
    "minEvidence": 1,
    "minFindings": 1,
    "minCitations": 1,
    "requireOfficialEvidence": true,
    "requireClaimClusters": true,
    "requireProviderUsageAny": ["fetch"],
    "maxFailed": 0
  },
  "scoring": {
    "threshold": 0.75,
    "weights": {
      "decomposition": 0.1,
      "planning": 0.15,
      "evidence": 0.3,
      "findings": 0.2,
      "citation": 0.1,
      "execution": 0.15
    }
  }
}
