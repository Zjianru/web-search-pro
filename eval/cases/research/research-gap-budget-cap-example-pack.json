{
  "id": "research-gap-budget-cap-example-pack",
  "suite": "research",
  "description": "Gap filling should not execute follow-up tasks when the remaining budget has already been exhausted.",
  "intent": "research",
  "tags": ["docs", "network", "gap-fill", "budget-cap"],
  "command": {
    "name": "research",
    "argv": ["Example.com docs latest updates", "--seed-url", "https://example.com", "--max-searches", "0", "--max-extracts", "0", "--json"]
  },
  "constraints": {
    "requiresNetwork": true
  },
  "expectedSignals": {
    "exitCode": 0,
    "topicTypeIn": ["docs"],
    "topicSignalsIncludeAll": ["docs", "latest"],
    "taskKindsIncludeAll": ["map"],
    "minEvidence": 1,
    "minFindings": 1,
    "minCitations": 1,
    "requireOfficialEvidence": true,
    "requireClaimClusters": true,
    "requireProviderUsageAny": ["fetch"],
    "requireGapResolutionAttempted": true,
    "maxFollowupTasksExecuted": 0,
    "maxFailed": 0
  },
  "scoring": {
    "threshold": 0.75,
    "weights": {
      "planning": 0.15,
      "evidence": 0.25,
      "findings": 0.15,
      "uncertainty": 0.15,
      "citation": 0.1,
      "execution": 0.2
    }
  }
}
