{
  "id": "h2h-live-locale-openai-china-news",
  "suite": "head-to-head-live",
  "description": "Chinese-language OpenAI news queries should return grounded multilingual results with recent-enough evidence.",
  "intent": "news",
  "tags": ["head-to-head", "live", "locale", "multilingual", "news"],
  "targets": [
    {
      "id": "web-search-pro",
      "command": {
        "name": "search",
        "argv": ["OpenAI 中国 最新 新闻", "--type", "news"]
      }
    },
    {
      "id": "web-search-plus",
      "externalCommand": {
        "cwd": "../web-search-plus",
        "bin": "python3",
        "argv": ["scripts/search.py", "-q", "OpenAI 中国 最新 新闻", "--type", "news"],
        "json": false
      }
    }
  ],
  "constraints": {
    "requiresNetwork": true,
    "requiredEnvAny": ["SERPER_API_KEY", "TAVILY_API_KEY", "SERPAPI_API_KEY", "QUERIT_API_KEY", "YOU_API_KEY"]
  },
  "comparativeMetrics": ["routeCorrectness", "freshness", "citationQuality"],
  "comparativeExpectations": {
    "preferredTarget": "web-search-pro",
    "mustBeatOn": [],
    "allowedTiesOn": ["routeCorrectness", "freshness", "citationQuality"]
  },
  "expectedSignals": {
    "selectedProviderIn": ["serpapi", "serper", "tavily", "querit", "you"],
    "minResults": 2,
    "mustIncludeDomainsAny": ["openai.com", "news.sciencenet.cn", "www.stcn.com", "www.voachinese.com"],
    "minDistinctUrls": 3,
    "maxResultAgeDays": 120,
    "maxFailed": 0
  },
  "scoring": {
    "threshold": 0.7,
    "weights": {
      "routing": 0.2,
      "coverage": 0.2,
      "freshness": 0.35,
      "citation": 0.25
    }
  }
}
